# Backend API adresi. EXPO_PUBLIC_ ön eki ile istemciye gömülür (gizli anahtar KOYMA).
#
# Android emülatörü (Android Studio AVD) + lokal backend:
#   localhost, emülatörün KENDİSİNİ işaret eder — bilgisayarını değil.
#   Host makineye ulaşmak için 10.0.2.2 kullan:
EXPO_PUBLIC_API_BASE_URL=http://GİZLİİİ

# Fiziksel cihaz (Expo Go) + lokal backend: bilgisayarının LAN IP'sini yaz, örn:
#   EXPO_PUBLIC_API_BASE_URL=http://GİZLİİİ
#
# Uzak (Render vb.) backend: doğrudan URL:
#   EXPO_PUBLIC_API_BASE_URL=https://gamepm.onrender.com
